{
  "name": "mindkeeper-openclaw",
  "version": "0.3.0",
  "description": "OpenClaw plugin for mindkeeper: auto-snapshot, diff, and rollback for agent context files",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "mindkeeper",
    "agent",
    "version-control",
    "snapshot",
    "rollback"
  ],
  "homepage": "https://github.com/seekcontext/mindkeeper#readme",
  "bugs": {
    "url": "https://github.com/seekcontext/mindkeeper/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seekcontext/mindkeeper.git",
    "directory": "packages/openclaw"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json",
    "scripts/postinstall-merge-config.cjs",
    "README.md"
  ],
  "scripts": {
    "build": "node build.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "postinstall": "node scripts/postinstall-merge-config.cjs"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "ai": "^6.0.116",
    "chokidar": "^4.0.0",
    "diff": "^7.0.0",
    "isomorphic-git": "^1.29.0",
    "minimatch": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
